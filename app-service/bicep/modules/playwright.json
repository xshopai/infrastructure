{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "10780732713120630904"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region for deployment"
      }
    },
    "resourcePrefix": {
      "type": "string",
      "metadata": {
        "description": "Resource naming prefix (xshopai-{suffix})"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags"
      }
    }
  },
  "variables": {
    "playwrightAccountName": "[format('pw-{0}', parameters('resourcePrefix'))]",
    "storageNameRaw": "[replace(format('stpw{0}', parameters('resourcePrefix')), '-', '')]",
    "storageName": "[if(greater(length(variables('storageNameRaw')), 24), substring(variables('storageNameRaw'), 0, 24), variables('storageNameRaw'))]"
  },
  "resources": [
    {
      "type": "Microsoft.AzurePlaywrightService/accounts",
      "apiVersion": "2024-12-01",
      "name": "[variables('playwrightAccountName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "regionalAffinity": "Enabled",
        "scalableExecution": "Enabled",
        "reporting": "Enabled"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "StorageV2",
      "sku": {
        "name": "Standard_LRS"
      },
      "properties": {
        "accessTier": "Hot",
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "allowSharedKeyAccess": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageName'), 'default')]",
      "properties": {
        "deleteRetentionPolicy": {
          "enabled": true,
          "days": 30
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}/{2}', variables('storageName'), 'default', 'playwright-results')]",
      "properties": {
        "publicAccess": "None"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageName'), 'default')]"
      ]
    },
    {
      "type": "Microsoft.Storage/storageAccounts/managementPolicies",
      "apiVersion": "2023-05-01",
      "name": "[format('{0}/{1}', variables('storageName'), 'default')]",
      "properties": {
        "policy": {
          "rules": [
            {
              "name": "cleanup-old-results",
              "enabled": true,
              "type": "Lifecycle",
              "definition": {
                "filters": {
                  "blobTypes": [
                    "blockBlob"
                  ],
                  "prefixMatch": [
                    "playwright-results/"
                  ]
                },
                "actions": {
                  "baseBlob": {
                    "delete": {
                      "daysAfterModificationGreaterThan": 90
                    }
                  }
                }
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    }
  ],
  "outputs": {
    "playwrightAccountName": {
      "type": "string",
      "value": "[variables('playwrightAccountName')]"
    },
    "playwrightDashboardUrl": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.AzurePlaywrightService/accounts', variables('playwrightAccountName')), '2024-12-01').dashboardUri]"
    },
    "playwrightServiceUrl": {
      "type": "string",
      "value": "[format('https://{0}.api.playwright.microsoft.com/accounts/{1}', parameters('location'), last(split(reference(resourceId('Microsoft.AzurePlaywrightService/accounts', variables('playwrightAccountName')), '2024-12-01').dashboardUri, '/')))]"
    },
    "playwrightWorkspaceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.AzurePlaywrightService/accounts', variables('playwrightAccountName'))]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageName')]"
    },
    "resultsContainerName": {
      "type": "string",
      "value": "playwright-results"
    }
  }
}